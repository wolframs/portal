    "ws": "^8.18.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
