{
  "name": "@animalabs/portal-relay",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "portal-relay": "./dist/src/index.js"
  },
  "description": "One Discord bot fronting many webhook personas: webhook + role pools, permission engine, WS gateway.",
  "scripts": {
